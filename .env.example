# Frontend: https://supabase.com/dashboard/project/_/settings/api → Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Frontend: https://supabase.com/dashboard/project/_/settings/api → anon (public)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side: same as VITE_SUPABASE_URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Server-side: https://supabase.com/dashboard/project/_/settings/api → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
